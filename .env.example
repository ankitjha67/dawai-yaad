# Dawai Yaad — Environment Variables
# Copy to .env and fill in your values

# ── Database ─────────────────────────────────────
DB_USER=dawai
DB_PASS=dawai_secret_2025
DB_HOST=db
DB_PORT=5432
DB_NAME=dawai_yaad
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ─────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Firebase Cloud Messaging ─────────────────────
FCM_SERVER_KEY=your-firebase-server-key
FCM_PROJECT_ID=your-firebase-project-id

# ── MinIO (File Storage) ─────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_USER=dawai_minio
MINIO_PASS=dawai_minio_secret
MINIO_BUCKET=dawai-documents
MINIO_SECURE=false

# ── OTP Provider (MSG91 for India) ───────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-template-id
MSG91_SENDER_ID=DAWAI

# ── WhatsApp (Twilio / Meta Business API) ────────
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=

# ── App Config ───────────────────────────────────
APP_NAME=Dawai Yaad
APP_VERSION=1.0.0
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
